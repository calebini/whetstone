{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortext.local/whetstone/contracts/schemas/unresolved_issues.schema.json",
  "title": "Whetstone Unresolved Issues",
  "type": "object",
  "additionalProperties": false,
  "required": ["round_number", "draft_hash", "unresolved_issues"],
  "properties": {
    "round_number": { "type": "integer", "minimum": 1 },
    "draft_hash": { "$ref": "common.schema.json#/$defs/sha256" },
    "unresolved_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "issue_id",
          "issue_fingerprint",
          "normalized_severity",
          "affected_sections",
          "claim",
          "in_scope",
          "blocking_acceptance"
        ],
        "properties": {
          "issue_id": { "$ref": "common.schema.json#/$defs/issueId" },
          "issue_fingerprint": { "$ref": "common.schema.json#/$defs/sha256" },
          "normalized_severity": { "$ref": "common.schema.json#/$defs/severity" },
          "affected_sections": { "$ref": "common.schema.json#/$defs/stringArray" },
          "claim": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "in_scope": { "type": "boolean" },
          "blocking_acceptance": { "type": "boolean" }
        }
      }
    }
  }
}
