{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortext.local/whetstone/contracts/schemas/rubric_manifest.schema.json",
  "title": "Whetstone Rubric Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "workflow",
    "rubric_profile",
    "rubric_source",
    "rubric_label",
    "rubric_path",
    "rubric_content_hash",
    "target_phase",
    "target_mode",
    "resolved_defaults",
    "configured_budgets",
    "warnings"
  ],
  "properties": {
    "generated_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "workflow": {
      "type": "string",
      "enum": ["exploratory", "mvp", "standard", "governance", "custom"]
    },
    "rubric_profile": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "rubric_source": {
      "type": "string",
      "enum": ["builtin", "custom"]
    },
    "rubric_label": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        { "type": "null" }
      ]
    },
    "rubric_path": { "$ref": "common.schema.json#/$defs/path" },
    "rubric_content_hash": { "$ref": "common.schema.json#/$defs/sha256" },
    "target_phase": { "$ref": "common.schema.json#/$defs/targetPhase" },
    "target_mode": { "$ref": "common.schema.json#/$defs/targetMode" },
    "resolved_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_phase", "target_mode", "convergence_max_rounds", "required_artifacts"],
      "properties": {
        "target_phase": { "$ref": "common.schema.json#/$defs/targetPhase" },
        "target_mode": { "$ref": "common.schema.json#/$defs/targetMode" },
        "convergence_max_rounds": { "type": "integer", "minimum": 1 },
        "required_artifacts": { "$ref": "common.schema.json#/$defs/stringArray" }
      }
    },
    "configured_budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_max_rounds", "convergence_max_rounds", "total_absolute_round_budget"],
      "properties": {
        "review_max_rounds": { "type": "integer", "minimum": 1 },
        "convergence_max_rounds": { "type": "integer", "minimum": 1 },
        "total_absolute_round_budget": { "type": "integer", "minimum": 2 }
      }
    },
    "warnings": { "$ref": "common.schema.json#/$defs/stringArray" }
  }
}
