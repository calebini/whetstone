{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortext.local/whetstone/contracts/schemas/client_telemetry.schema.json",
  "title": "Whetstone Client Telemetry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "round_number",
    "phase",
    "profile",
    "client_role",
    "artifact_name",
    "attempt_number",
    "client",
    "started_at",
    "finished_at",
    "duration_ms",
    "duration_api_ms",
    "exit_code",
    "timed_out",
    "session_id",
    "num_turns",
    "stop_reason",
    "terminal_reason",
    "total_cost_usd",
    "usage",
    "model_usage",
    "raw_envelope_path",
    "stdout_path",
    "stderr_path",
    "telemetry_source"
  ],
  "properties": {
    "generated_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "round_number": { "type": "integer", "minimum": 1 },
    "phase": {
      "type": "string",
      "enum": ["phase_1", "phase_2"]
    },
    "profile": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "client_role": {
      "type": "string",
      "enum": ["reviewer", "editor"]
    },
    "artifact_name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "command", "configured_version", "observed_version", "model"],
      "properties": {
        "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "command": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "configured_version": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "observed_version": {
          "anyOf": [
            { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        },
        "model": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "started_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "finished_at": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "duration_ms": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "duration_api_ms": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "exit_code": {
      "anyOf": [
        { "type": "integer" },
        { "type": "null" }
      ]
    },
    "timed_out": { "type": "boolean" },
    "session_id": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        { "type": "null" }
      ]
    },
    "num_turns": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "stop_reason": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        { "type": "null" }
      ]
    },
    "terminal_reason": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        { "type": "null" }
      ]
    },
    "total_cost_usd": {
      "anyOf": [
        { "type": "number" },
        { "type": "null" }
      ]
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cache_creation_input_tokens",
        "cache_read_input_tokens",
        "total_tokens",
        "provider_raw"
      ],
      "properties": {
        "input_tokens": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "output_tokens": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "cache_creation_input_tokens": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "cache_read_input_tokens": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "total_tokens": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "provider_raw": {
          "anyOf": [
            { "type": "object" },
            { "type": "null" }
          ]
        }
      }
    },
    "model_usage": {
      "anyOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "raw_envelope_path": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/path" },
        { "type": "null" }
      ]
    },
    "stdout_path": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/path" },
        { "type": "null" }
      ]
    },
    "stderr_path": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/path" },
        { "type": "null" }
      ]
    },
    "telemetry_source": {
      "type": "string",
      "enum": ["claude_json_envelope", "codex_stdout", "codex_json_envelope", "process_metadata", "unavailable"]
    }
  }
}
